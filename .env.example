# One-project backend-only setup:
# point MAIN and CHAT at the same Supabase project and Postgres database.

# Supabase REST
SUPABASE_MAIN_URL=https://your-project.supabase.co
SUPABASE_MAIN_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_MAIN_SCHEMA=rg_backend
SUPABASE_CHAT_URL=https://your-project.supabase.co
SUPABASE_CHAT_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_CHAT_SCHEMA=rg_chat

# Supabase Postgres
DATABASE_URL=postgresql://postgres.your_project_ref:password@aws-1-your-region.pooler.supabase.com:6543/postgres
DATABASE_CHAT_URL=postgresql://postgres.your_project_ref:password@aws-1-your-region.pooler.supabase.com:6543/postgres

# Core runtime
API_AUTH_TOKEN=change-me
PREFECT_API_URL=http://prefect-server:4200/api
FRONTEND_URL=https://app.bookmyleads.ai
PORTAL_JWT_SECRET=change-me

# AI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://ironclaw.openai.azure.com/openai/v1
AZURE_OPENAI_MODEL=gpt-4.1
OPENROUTER_API_KEY=
OPENROUTER_TESTING_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# Optional integrations
SLACK_BOT_TOKEN=
GIPHY_API_KEY=
SIGNAL_HOUSE_API_KEY=
SIGNAL_HOUSE_AUTH_TOKEN=
GHL_SNAPSHOT_API_KEY=
GHL_SNAPSHOT_LOCATION_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=BookMyLeads <noreply@send.bookmyleads.ai>
