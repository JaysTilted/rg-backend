flowchart TB
  classDef store fill:#ecfccb,stroke:#65a30d,color:#1a2e05
  classDef svc fill:#ffedd5,stroke:#c2410c,color:#0f172a
  classDef ai fill:#e0e7ff,stroke:#4f46e5,color:#0f172a
  classDef ext fill:#fce7f3,stroke:#db2777,color:#0f172a
  classDef gap fill:#fee2e2,stroke:#b91c1c,color:#0f172a,stroke-dasharray: 4 2

  %% ────────── Cold Outreach (automation-platform) ──────────
  subgraph COLD["🎯 Cold Outreach — automation-platform/src/services/sms"]
    direction TB
    ICP["<b>Iron ACQ scraper</b><br/>populates <code>app.leads</code><br/>with <code>icp_arm</code> (curiosity / outcome),<br/><code>icp_tier_v2</code>, <code>category_normalized</code>"]:::svc
    LEADS_DB[("<b>app.leads</b>")]:::store
    ROUTER["<b>router.py</b><br/>scans every 60s<br/><code>ARM_TO_CAMPAIGN</code>:<br/>curiosity→seg-a, outcome→seg-b"]:::svc
    CAMPAIGN_CFG[("<b>app.sms_campaign_config</b><br/>drip_sequence.steps<br/>body + CTA copy")]:::store
    QUEUE[("<b>app.scheduled_sends</b><br/>work queue")]:::store
    DISPATCH["<b>dispatcher.py</b><br/>claims jobs FOR UPDATE SKIP LOCKED<br/>renders via copy_renderer.py<br/>checks business hours / DNC / stop"]:::svc
    UPSERT["<b>GHL upsert_contact</b><br/>tags: <code>src:cold-sms</code>, &lt;niche&gt;<br/>⚠️ <b>ADD</b>: <code>campaign:curiosity</code> / <code>campaign:outcome</code><br/>⚠️ <b>ADD</b>: <code>Agent Type = setter_1</code>"]:::gap

    ICP --> LEADS_DB
    LEADS_DB --> ROUTER
    ROUTER --> CAMPAIGN_CFG
    ROUTER --> QUEUE
    QUEUE --> DISPATCH
    DISPATCH --> UPSERT
  end

  %% ────────── Pitch Templates ──────────
  subgraph PITCH["🎤 Two Pitch Openers (× 2 framings each = 4 variants)"]
    direction LR
    P1["<b>Pitch 1 — Website bait</b><br/>&quot;Hey it's Scott, I build websites for {niche} in {state}.<br/>Noticed {business} doesn't have one.&quot;<br/>+ &quot;I know it sounds crazy but I threw one together real quick. Want to see it?&quot;"]:::svc
    P2["<b>Pitch 2 — Pay-on-results</b><br/>&quot;Hey it's Scott, saw {business} in {state}.<br/>I help {niche} pros book more jobs, pay on results.&quot;<br/>+ &quot;Want me to show you how?&quot;"]:::svc
  end

  %% ────────── Transport ──────────
  subgraph SEND["📤 Outbound SMS Transport"]
    direction LR
    GHL_MSG["<b>GHL POST /conversations/messages</b><br/>type: SMS, no fromNumber<br/>conversationProviderId: Signal House custom"]:::ext
    SH_OUT["<b>Signal House</b><br/><code>+1 267-871-8781</code><br/>campaign CU1TW6Q"]:::ext
    LEAD_PHONE["📱 Lead's phone"]:::ext
  end

  UPSERT --> GHL_MSG
  GHL_MSG --> SH_OUT
  SH_OUT --> LEAD_PHONE
  PITCH -. "rendered copy" .-> DISPATCH

  %% ────────── Reply path ──────────
  subgraph REPLY["📥 Inbound Reply"]
    direction TB
    SH_IN["<b>Signal House inbound</b>"]:::ext
    GHL_CONV["<b>GHL Conversation</b><br/>TYPE_CUSTOM_SMS"]:::ext
    WF1["<b>GHL Workflow 1</b><br/>&quot;1 - Receive &amp; Process DMs&quot;<br/><code>2dc8ba3b-...</code><br/>⚠️ <b>currently DRAFT</b>"]:::gap
    WEBHOOK["<b>POST /webhook/reply</b><br/>rg-backend FastAPI<br/>validates Bearer token"]:::svc
    DEBOUNCE["<b>debounce.py</b><br/>reads <code>Agent Type</code> custom field → <code>ctx.agent_type</code><br/>reads <code>Lead Source</code>, <code>Channel</code><br/>90s window to batch rapid-fire msgs"]:::svc
  end

  LEAD_PHONE -. "reply" .-> SH_IN
  SH_IN --> GHL_CONV
  GHL_CONV --> WF1
  WF1 --> WEBHOOK
  WEBHOOK --> DEBOUNCE

  %% ────────── AI Reply Agent ──────────
  subgraph AGENT["🤖 AI Reply Agent — rg-backend/app/text_engine"]
    direction TB
    PIPELINE["<b>pipeline.py</b><br/>orchestrates the full run"]:::ai
    ENTITY_CFG[("<b>rg_backend.entities</b> 55b37690<br/>system_config.setters.setter_1<br/>services, booking, transfer, security<br/>test_mode.allowed_contact_ids")]:::store
    DATA_LOAD["<b>data_loading.py</b><br/>_compile_system_config<br/>resolves <code>_matched_setter</code><br/>compiles agent_prompt, services,<br/>followup config, case studies"]:::ai
    AZURE["<b>Azure GPT-4.1</b><br/>ironclaw.openai.azure.com/openai/v1<br/>OpenRouter fallback"]:::ai
    TAGS_READ["reads <code>ctx.contact_tags</code><br/>looks for <code>campaign:curiosity</code><br/>or <code>campaign:outcome</code><br/>to stay framing-consistent"]:::ai
    SECURITY["<b>security screening</b><br/>prompt protection, jailbreak, compliance"]:::ai
    SPLIT["<b>message splitter</b><br/>1-3 SMS bubbles"]:::ai
    DELIVERY["<b>GHL POST /conversations/messages</b><br/>→ Signal House → lead's phone"]:::svc
  end

  DEBOUNCE --> PIPELINE
  PIPELINE --> DATA_LOAD
  DATA_LOAD --> ENTITY_CFG
  ENTITY_CFG --> DATA_LOAD
  DATA_LOAD --> TAGS_READ
  TAGS_READ --> AZURE
  AZURE --> SECURITY
  SECURITY --> SPLIT
  SPLIT --> DELIVERY
  DELIVERY --> GHL_MSG

  %% ────────── Chat + Follow-up + Booking ──────────
  subgraph PERSIST["💾 State &amp; Scheduling"]
    direction TB
    CHAT[("<b>rg_chat.iron_automations_chat</b><br/>full message history<br/>per entity")]:::store
    LEADS2[("<b>rg_backend.leads</b><br/>lead record, last_reply_*")]:::store
    FU_QUEUE[("<b>rg_backend.scheduled_messages</b><br/>follow-up + reactivation jobs")]:::store
    FU_LOOP["<b>message_scheduler_loop.py</b><br/>safety_net sweep every 30 min<br/>cadence: 6h, 1d, 3d, 7d, 14d"]:::svc
    BOOKINGS[("<b>rg_backend.bookings</b>")]:::store
  end

  PIPELINE --> CHAT
  PIPELINE --> LEADS2
  PIPELINE --> FU_QUEUE
  FU_LOOP --> FU_QUEUE
  FU_LOOP --> PIPELINE

  %% ────────── Booking path ──────────
  subgraph BOOK["📅 Booking &amp; Post-Call"]
    direction LR
    CAL["<b>Discovery Call Calendar</b><br/><code>xFDiv47ToGQ9ZQ2PadXG</code><br/>45 min · Google Meet"]:::ext
    WF5["<b>GHL Workflow 5</b><br/>Log Booking + Reminders<br/><code>37d917d0-...</code><br/>⚠️ currently DRAFT"]:::gap
    LOG_BOOK["<b>POST /webhook/log-booking</b><br/>cancels pending follow-ups<br/>schedules reminders"]:::svc
  end

  PIPELINE -. "book_appointment tool" .-> CAL
  CAL --> WF5
  WF5 --> LOG_BOOK
  LOG_BOOK --> BOOKINGS
  LOG_BOOK --> FU_QUEUE

  %% ────────── Human Scott fallback ──────────
  subgraph HUMAN["👤 Human Takeover (currently primary)"]
    direction TB
    SCOTT_G["<b>Scott Gonzales</b><br/>user_id <code>y4s1yUWOiouIRW1TUEZk</code><br/>replies manually through GHL UI"]:::ext
    WF3["<b>GHL Workflow 3</b><br/>Sync bot on/off<br/><code>df27d21f-...</code><br/>⚠️ DRAFT"]:::gap
  end

  GHL_CONV --> SCOTT_G
  SCOTT_G -. "manual reply" .-> GHL_MSG
  WF3 -. "pause bot on staff activity" .-> ENTITY_CFG

  %% ────────── test_mode gate ──────────
  GATE["<b>test_mode gate</b><br/>in main.py /webhook/reply<br/>rejects non-allowlisted contacts<br/>currently enabled, Jay contact only"]:::gap
  WEBHOOK -. "allowlist check" .-> GATE
  GATE -. "if not allowed" .-> DEBOUNCE

  %% Layout hints
  COLD ~~~ PITCH
  PITCH ~~~ SEND
  SEND ~~~ REPLY
  REPLY ~~~ AGENT
  AGENT ~~~ PERSIST
  PERSIST ~~~ BOOK
  BOOK ~~~ HUMAN
